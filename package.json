{
  "name": "gamecoach",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && wrangler pages dev",
    "deploy": "npm run pages:build && wrangler pages deploy",
    "db:create": "wrangler d1 create gamecoach-db",
    "db:migrate": "wrangler d1 execute gamecoach-db --file=./migrations/0001_init.sql",
    "db:migrate:local": "wrangler d1 execute gamecoach-db --local --file=./migrations/0001_init.sql",
    "contract:compile": "hardhat compile",
    "contract:deploy": "hardhat run scripts/deploy.ts --network sepolia"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "next": "^15.5.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260530.1",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "hardhat": "^3.7.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.95.0"
  }
}
